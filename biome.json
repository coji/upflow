{
  "$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
  "assist": { "actions": { "source": { "organizeImports": "off" } } },
  "files": {
    "includes": [
      "**",
      "!app/components/ui",
      "!app/styles/globals.css",
      "!lab",
      "!batch/github/graphql-env.d.ts",
      "!batch/github/schema.graphql"
    ]
  },
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "useAwait": "error",
        "noRedeclare": "off"
      }
    }
  }
}

BETTER_AUTH_SECRET=your-better-auth-secret-at-least-32-chars
BETTER_AUTH_URL=http://localhost:5173
UPFLOW_DATA_DIR=./data

# GitHub REST API calls go to `pnpm emulate:github`.
GITHUB_API_BASE_URL=http://localhost:4000

# Matches emulate.config.yaml.
GITHUB_CLIENT_ID=Iv1.upflow_local
GITHUB_CLIENT_SECRET=upflow_local_secret

# Optional unless exercising GitHub App flows locally.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

SEED_ADMIN_GITHUB_LOGIN=octocat

{
  "name": "upflow",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "run-s build:react-router build:job",
    "build:job": "esbuild --platform=node --format=esm ./batch/job-schedular.ts --outdir=build --bundle --packages=external",
    "build:react-router": "react-router build",
    "dev": "react-router dev",
    "start": "node server.mjs",
    "format": "prettier --cache -c . --experimental-cli",
    "format:fix": "prettier --cache -w . --experimental-cli",
    "lint": "biome lint .",
    "setup": "atlas migrate apply --env local --url 'sqlite://data/data.db' && tsx db/seed.ts",
    "db:generate": "kysely-codegen --dialect sqlite --out-file app/services/type.ts --url ./data/data.db --camel-case",
    "db:migrate": "atlas migrate diff --env local",
    "db:apply": "atlas migrate apply --env local --url 'sqlite://data/data.db'",
    "test": "vitest --run",
    "test:e2e": "run-s test:e2e:build test:e2e:run",
    "test:e2e:build": "run-s build",
    "test:e2e:run": "playwright test",
    "typecheck": "react-router typegen && tsc -b",
    "validate": "run-s lint format typecheck build test"
  },
  "dependencies": {

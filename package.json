{
  "name": "upflow",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "run-s build:react-router build:job",
    "build:job": "esbuild --platform=node --format=esm ./batch/job-scheduler.ts --outdir=build --bundle --packages=external",
    "build:react-router": "react-router build",
    "dev": "react-router dev",
    "start": "node server.mjs",
    "format": "prettier --cache -c . --experimental-cli",
    "format:fix": "prettier --cache -w . --experimental-cli",
    "lint": "biome lint .",
    "db:setup": "mkdir -p data && run-s db:apply db:seed",
    "db:seed": "tsx db/seed.ts",
    "db:generate": "run-s db:generate:shared db:generate:tenant",
    "db:generate:shared": "kysely-codegen --dialect sqlite --out-file app/services/type.ts --url ./data/data.db --camel-case",
    "db:generate:tenant": "kysely-codegen --dialect sqlite --out-file app/services/tenant-type.ts --url ./data/tenant_seed.db --camel-case",
    "db:migrate": "run-s db:migrate:shared db:migrate:tenant",
    "db:migrate:shared": "atlas migrate diff --env local",
    "db:migrate:tenant": "atlas migrate diff --env tenant",
    "db:apply": "run-s db:apply:shared db:apply:tenant",
    "db:apply:shared": "atlas migrate apply --env local --url 'sqlite://data/data.db'",
    "db:apply:tenant": "tsx db/apply-tenant-migrations.ts",
    "batch:golden:snapshot": "pnpm tsx --env-file .env batch/scripts/golden-snapshot.ts",
    "batch:golden:compare": "pnpm tsx --env-file .env batch/scripts/golden-compare.ts",
    "graphql:schema": "cp node_modules/@octokit/graphql-schema/schema.graphql batch/provider/github/schema.graphql",
    "test": "vitest --run",
    "test:e2e": "run-s test:e2e:build test:e2e:run",
    "test:e2e:build": "run-s build",
    "test:e2e:run": "playwright test",
    "typecheck": "react-router typegen && tsc -b",
    "validate": "run-s lint format typecheck build test",
    "lab:fetch": "pnpm tsx lab/fetch.ts",
    "lab:serve": "python3 -m http.server 8787 -d lab/output"
  },
  "dependencies": {
    "@coji/zodix": "0.7.0",
    "@conform-to/react": "1.16.0",
    "@conform-to/zod": "1.16.0",
    "@epic-web/remember": "1.1.0",
    "@googleapis/sheets": "13.0.1",
    "@octokit/plugin-rest-endpoint-methods": "17.0.0",
    "@react-router/express": "7.13.0",
    "@react-router/node": "7.13.0",
    "@react-router/serve": "7.13.0",
    "@tanstack/react-table": "8.21.3",
    "better-auth": "1.4.17",
    "better-sqlite3": "12.6.2",
    "class-variance-authority": "0.7.1",
    "cleye": "2.2.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "compression": "1.8.1",
    "consola": "3.4.2",
    "cross-env": "10.1.0",
    "date-fns": "4.1.0",
    "dayjs": "1.11.19",
    "debug": "4.4.3",
    "dotenv": "17.2.3",
    "embla-carousel-react": "8.6.0",
    "express": "5.2.1",
    "globby": "16.1.0",
    "google-auth-library": "10.5.0",
    "gql.tada": "1.9.0",
    "graphql": "16.12.0",
    "isbot": "5.1.34",
    "kysely": "0.28.10",
    "lucide-react": "0.563.0",
    "morgan": "1.10.1",
    "nanoid": "5.1.6",
    "next-themes": "0.4.6",
    "node-schedule": "2.1.1",
    "octokit": "5.0.5",
    "radix-ui": "latest",
    "react": "19.2.4",
    "react-day-picker": "9.13.0",
    "react-dom": "19.2.4",
    "react-resizable-panels": "3.0.2",
    "react-router": "7.13.0",
    "recharts": "2.15.3",
    "remeda": "2.33.4",
    "remix-toast": "4.0.0",
    "sonner": "2.0.7",
    "tailwind-merge": "3.4.0",
    "tailwindcss-animate": "1.0.7",
    "tiny-invariant": "1.3.3",
    "ts-pattern": "5.9.0",
    "vaul": "1.1.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.13",
    "@google/genai": "1.42.0",
    "@octokit/graphql-schema": "15.26.1",
    "@octokit/types": "16.0.0",
    "@playwright/test": "1.58.0",
    "@react-router/dev": "7.13.0",
    "@tailwindcss/vite": "4.1.18",
    "@types/better-sqlite3": "7.6.13",
    "@types/compression": "1.8.1",
    "@types/debug": "4.1.12",
    "@types/express": "5.0.6",
    "@types/morgan": "1.9.10",
    "@types/node": "25.0.10",
    "@types/node-schedule": "2.1.8",
    "@types/react": "19.2.10",
    "@types/react-dom": "19.2.3",
    "cc-hooks-ts": "2.1.19",
    "dotenv-cli": "11.0.0",
    "esbuild": "0.27.2",
    "esbuild-plugin-clean": "1.0.1",
    "kysely-codegen": "0.19.0",
    "msw": "2.12.7",
    "npm-run-all": "4.1.5",
    "prettier": "3.8.1",
    "prettier-plugin-organize-imports": "4.3.0",
    "prettier-plugin-tailwindcss": "0.7.2",
    "react-router-auto-routes": "0.8.2",
    "tailwindcss": "4.1.18",
    "tsconfig-paths": "4.2.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vite-plugin-devtools-json": "1.0.0",
    "vite-tsconfig-paths": "6.0.5",
    "vitest": "4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "@tailwindcss/oxide",
      "better-sqlite3",
      "esbuild",
      "msw"
    ]
  }
}
